# =============================================================================
# MindFlow — Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to git. .env.example is safe to commit.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase (required)
# Get these from: Supabase Dashboard → Project Settings → API
# The anon key is safe to expose on the client — RLS enforces row-level access.
# -----------------------------------------------------------------------------
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# -----------------------------------------------------------------------------
# AI (required for AI features to work)
#
# CURRENT STATE: The app calls the Anthropic API directly (claude-sonnet-4)
# from the browser via callClaude() in src/mindflow.jsx.
# Without this key, all AI features (parseDump, evening review, focus suggest)
# will silently fail with a 401 error.
#
# Get your key at: https://console.anthropic.com
#
# IMPORTANT: This exposes the key client-side. For production, move AI calls
# to a Supabase Edge Function so the key is never sent to the browser.
# -----------------------------------------------------------------------------
VITE_ANTHROPIC_API_KEY=sk-ant-your-key-here

# -----------------------------------------------------------------------------
# Future (not used yet — add when integrating Gemini for parseDump)
# -----------------------------------------------------------------------------
# VITE_GEMINI_API_KEY=your_gemini_api_key_here
