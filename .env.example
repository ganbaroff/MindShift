# MindShift — Environment Variables
# Copy to .env and fill in values. Never commit .env to git.

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard > Settings > API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
# New key format since 2025 — starts with sb_publishable_
# Old eyJ... JWT format still accepted but being deprecated by Supabase
VITE_SUPABASE_ANON_KEY=sb_publishable_your-key-here

# Service role key — for local CLI usage only (migrations, edge function dev).
# NEVER prefix with VITE_ — must never reach the browser bundle.
# Set via: Supabase Dashboard > Settings > API > Secret keys
# SUPABASE_SERVICE_ROLE_KEY=sb_secret_your-key-here

# ── AI (Google Gemini) ────────────────────────────────────────────────────────
# Used ONLY in Supabase Edge Functions (server-side), NEVER exposed to browser.
# Get from: https://aistudio.google.com/apikey
# Set via: supabase secrets set GEMINI_API_KEY=AIza...
# GEMINI_API_KEY=AIza...   ← set in Supabase dashboard only

# ── Sentry (error tracking) ──────────────────────────────────────────────────
# Optional: set to enable production error tracking.
# Found in: Sentry Dashboard > Project > Settings > Client Keys (DSN)
VITE_SENTRY_DSN=https://your-dsn.ingest.sentry.io/your-project-id

# ── VOLAURA Ecosystem Integration (optional) ─────────────────────────────────
# Enables cross-product character events (focus sessions → XP, streaks, vitals).
# Leave empty to disable silently. Get URL from VOLAURA team.
VITE_VOLAURA_API_URL=

# ── Android release signing (Play Store internal-test track) ─────────────────
# Used by android/app/build.gradle to sign the release AAB produced by
# `./gradlew bundleRelease`. Required to ship to the Play Store. NEVER commit
# the keystore or these passwords. .gitignore already excludes *.keystore /
# *.jks / *.p12 / *.p8 / *.pem and release.keystore.bak-* — keep it that way.
#
# Why it matters: same keystore = same signing fingerprint = Play Store
# treats new AAB as an upgrade of the installed app. Local user data
# (tasks, sessions, streaks) is preserved across versions. Lose the
# keystore and you lose the ability to update the listing — forever.
#
# These are READ by gradle from the shell environment, not from .env.
# Set them in your shell before running gradle. Examples:
#
#   PowerShell (Windows, CEO setup):
#     $env:MINDSHIFT_KEYSTORE_PASSWORD = "<store-password>"
#     $env:MINDSHIFT_KEY_ALIAS         = "mindshift"
#     $env:MINDSHIFT_KEY_PASSWORD      = "<key-password>"
#     # Optional, defaults to android/release.keystore:
#     # $env:MINDSHIFT_KEYSTORE_PATH   = "C:\path\to\release.keystore"
#     cd android; .\gradlew.bat bundleRelease
#
#   bash / zsh (CI, macOS, Linux):
#     export MINDSHIFT_KEYSTORE_PASSWORD='<store-password>'
#     export MINDSHIFT_KEY_ALIAS='mindshift'
#     export MINDSHIFT_KEY_PASSWORD='<key-password>'
#     cd android && ./gradlew bundleRelease
#
# If any of the three required vars is missing, gradle fails LOUDLY (no
# silent fallback to debug signing — that would break Play Store upgrades).
# MINDSHIFT_KEYSTORE_PATH=android/release.keystore
# MINDSHIFT_KEYSTORE_PASSWORD=
# MINDSHIFT_KEY_ALIAS=
# MINDSHIFT_KEY_PASSWORD=

# ── Notes ─────────────────────────────────────────────────────────────────────
# VITE_* variables are bundled into the client bundle and visible to users.
# Never put secret keys (Anthropic API key, Supabase service key) in VITE_ vars.
# All AI calls go through Supabase Edge Functions with JWT auth.
