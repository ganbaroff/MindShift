{
  "name": "mindshift",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "overrides": {
    "serialize-javascript": "^7.0.5"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "cap:sync": "npm run build && npx cap sync",
    "cap:ios": "npm run build && npx cap sync && npx cap open ios",
    "cap:android": "npm run build && npx cap sync && npx cap open android",
    "cap:run:android": "npx cap run android --livereload --external",
    "screenshots": "tsx scripts/capture-screenshots.ts",
    "screenshots:prod": "SCREENSHOTS_BASE_URL=https://mindshift-umber.vercel.app tsx scripts/capture-screenshots.ts",
    "translate": "node scripts/translate.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@sentry/react": "^10.42.0",
    "@supabase/supabase-js": "^2.98.0",
    "@tanstack/react-query": "^5.90.21",
    "@vercel/analytics": "^1.5.0",
    "autoprefixer": "^10.4.27",
    "i18next": "^25.1.2",
    "idb-keyval": "^6.2.2",
    "lucide-react": "^0.577.0",
    "motion": "^12.35.1",
    "postcss": "^8.5.8",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^15.5.1",
    "react-router-dom": "^7.13.1",
    "sonner": "^2.0.7",
    "tailwindcss": "^4.2.1",
    "web-vitals": "^5.0.3",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@sentry/cli": "^2.42.2",
    "@playwright/test": "^1.58.2",
    "@rollup/plugin-terser": "^1.0.0",
    "@tailwindcss/vite": "^4.2.1",
    "@types/jsdom": "^28.0.0",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/ui": "^4.0.18",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^28.1.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "tsx": "^4.19.2",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.18"
  },
