# MindFocus — Environment Variables
# Copy to .env.local and fill in your values.
# Never commit .env.local to source control (it is in .gitignore).
#
# All VITE_* variables are bundled into the client-side JS and are
# therefore publicly visible. Only keys safe for public exposure go here.
# See docs/bolts/adr/0014-pwa-deploy.md for security notes.

# ── Supabase ──────────────────────────────────────────────────────────────────
# Project URL (Settings → API → Project URL)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Anon / public key — safe to expose, protected by Row Level Security (RLS)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Anthropic Claude API ──────────────────────────────────────────────────────
# Used for AI brain dump parsing, day plan suggestions, evening reviews.
# ⚠️  This key ships to the browser. Use a restricted-scope key with:
#     • Usage limits set in the Anthropic Console
#     • Rotate immediately if leaked
VITE_ANTHROPIC_API_KEY=sk-ant-api03-...
